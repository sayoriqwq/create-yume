const headerPattern = /^(?:(?::[a-z0-9_+-]+:|[\p{Extended_Pictographic}\uFE0F\u200D]+)\s+)?([a-z]+)(?:\(([^()\r\n]*)\))?(!?): (.+)$/u

export default {
  extends: ['@commitlint/config-conventional'],
  parserPreset: {
    parserOpts: {
      headerPattern,
      headerCorrespondence: ['type', 'scope', 'breaking', 'subject'],
    },
  },
}
